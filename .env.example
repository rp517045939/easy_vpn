# easy_vpn Server 环境变量
# 复制为 .env 并填入真实值（.env 不会被提交到 git）

# JWT 签名密钥（随机字符串，建议 32 位以上）
SECRET_KEY=change-me-to-a-long-random-string

# 管理面板登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Client 注册时使用的共享 token
CLIENT_TOKEN=change-me-to-another-random-string

# 管理面板域名（用于区分面板请求和隧道请求）
PANEL_HOST=vpn.ruanpengpeng.cn

# HTTP 隧道子域名的根域名（UI 中显示的后缀）
HTTP_DOMAIN=vpn.ruanpengpeng.cn

# 服务监听端口
PORT=8080

# 数据目录（Docker 内默认 /app/data，本地开发留空即可自动用 server/data）
# DATA_DIR=/app/data
