# easy_vpn Server 环境变量
# 复制为 .env 并填入真实值（.env 不会被提交到 git）

# JWT 签名密钥（随机字符串，越长越好）
SECRET_KEY=change-me-to-a-long-random-string

# 管理面板登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Client 注册时使用的共享 token
CLIENT_TOKEN=change-me-to-another-random-string

# 服务监听端口（对应 docker-compose 和 Nginx proxy_pass）
PORT=8080
