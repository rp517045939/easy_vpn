# easy_vpn Server 环境变量
# 复制为 .env 并填入真实值（.env 不会被提交到 git）

# JWT 签名密钥（随机字符串，建议 32 位以上）
SECRET_KEY=change-me-to-a-long-random-string

# 管理面板登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 证书管理员邮箱（留空则 certbot 匿名注册，收不到续期/异常通知）
ADMIN_EMAIL=

# Client 注册时使用的共享 token
CLIENT_TOKEN=change-me-to-another-random-string

# 管理面板域名（用于区分面板请求和隧道请求）
PANEL_HOST=vpn.ruanpengpeng.cn

# HTTP 隧道子域名的根域名（UI 中显示的后缀）
HTTP_DOMAIN=vpn.ruanpengpeng.cn

# 服务监听端口
PORT=8080

# TCP 隧道推荐端口段：用于自动分配和管理面板推荐列表
TCP_PORT_MIN=2200
TCP_PORT_MAX=2299

# TCP 隧道允许手动填写的服务端端口段
TCP_PORT_ALLOW_MIN=1
TCP_PORT_ALLOW_MAX=65535

# 数据目录（Docker 内默认 /app/data，本地开发留空即可自动用 server/data）
# DATA_DIR=/app/data
